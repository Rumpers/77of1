# Worker environment variables — copy to .env.local for local dev.
# Required env vars for the voice-generation worker.

# ── Shared GMI API key (used for both LLM and TTS) ───────────────────────────
GMI_API_KEY=your_gmi_api_key_here

# ── GMI TTS async request queue (console.gmicloud.ai — DISTINCT from LLM host) ─
# Do not use api.gmi-serving.com here — voice lives on console.gmicloud.ai.
# Confirmed in 03-01-GMI-TTS-CONTRACT.md (2026-05-30).
GMI_TTS_BASE_URL=https://console.gmicloud.ai
GMI_TTS_MODEL_ID=minimax-tts-speech-2.6-hd
# Preset voice_id used when twins.voice_id is null (before clone Step A runs).
# Example: English_expressive_narrator. Must be a valid GMI preset voice_id.
GMI_TTS_FALLBACK_VOICE_ID=English_expressive_narrator
# Optional — poll interval for submit→poll loop (ms). Default: 1500.
GMI_TTS_POLL_INTERVAL_MS=1500
# Optional — overall submit+poll+fetch timeout (ms). Default: 30000.
GMI_TTS_TIMEOUT_MS=30000

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/lala

# ── Telegram (fan-twin outbound only, no .launch()) ───────────────────────────
TELEGRAM_BOT_TOKEN_FAN_TWIN=your_fan_twin_bot_token_here

# ── Object Storage ────────────────────────────────────────────────────────────
REPLIT_OBJECT_STORAGE_BUCKET=your_bucket_name_here

# ── Helicone (optional — enables per-creator cost dashboards) ─────────────────
HELICONE_API_KEY=

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=
