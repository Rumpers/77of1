# 7of1 — environment variables
# Copy this file to .env.local for local development (never commit real values).
# In Replit, set these as Secrets (the Replit Secrets panel maps them to env vars at runtime).
# In production (GCP Cloud Run), set these as Cloud Run environment variables / Secret Manager refs.
#
# Required vars are marked [REQUIRED] — the API server will crash on startup if these are missing.
# Optional vars are marked [OPTIONAL] — features degrade gracefully without them.

# ──────────────────────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────────────────────

# TCP port the API server listens on. Replit sets this automatically.
# [REQUIRED]
PORT=8080

NODE_ENV=development

# ──────────────────────────────────────────────────────────────────────────────
# Supabase (auth + database)
# ──────────────────────────────────────────────────────────────────────────────

# From Supabase dashboard → Project Settings → API
# [REQUIRED]
SUPABASE_URL=

# Supabase anonymous/public key (safe to expose to the browser)
# [REQUIRED]
SUPABASE_ANON_KEY=

# Supabase service role key (server-side only — never expose to the client)
# [REQUIRED]
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Redis / BullMQ job queue
# ──────────────────────────────────────────────────────────────────────────────

# Redis connection URL. Queue features are disabled if not set.
# Format: redis://:<password>@<host>:<port>
# [OPTIONAL]
REDIS_URL=

# ──────────────────────────────────────────────────────────────────────────────
# AI provider (GMI)
# ──────────────────────────────────────────────────────────────────────────────

# GMI API key for text/voice/video generation
# [OPTIONAL — AI generation features are disabled without this]
GMI_API_KEY=

# GMI API base URL (e.g. https://api.gmi.ai/v1)
# [OPTIONAL]
GMI_API_BASE_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Application URL
# ──────────────────────────────────────────────────────────────────────────────

# Canonical public URL of this deployment — used in magic link redirects.
# Must be the Replit deployment URL in Replit, or the Cloud Run service URL in GCP.
# No trailing slash.
# [OPTIONAL — magic links will fail if not set]
NEXT_PUBLIC_APP_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────────────────────────────────────

# Sentry DSN for error reporting
# [OPTIONAL]
SENTRY_DSN=

# Helicone API key for LLM observability
# [OPTIONAL]
HELICONE_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Health check auth
# ──────────────────────────────────────────────────────────────────────────────

# Shared secret for protected health endpoints (/api/health/db, /api/health/queue, /api/health/providers).
# Set X-Health-Secret: <value> on requests to those endpoints.
# If not set, the endpoints are open (acceptable for dev; set this in production).
# Generate with: openssl rand -hex 32
# [OPTIONAL — recommended in production]
HEALTH_SECRET=
