# 7of1 Web App — environment variables
# Set these in Replit Secrets (never commit real values).

# HMAC-SHA256 signing key for session tokens.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Supabase project credentials (from Supabase dashboard → Project Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Redis/BullMQ connection (optional — leave blank to stub queue features)
REDIS_URL=
