# API Server environment variables — copy to .env.local for local dev.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/lala
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Session / Security ────────────────────────────────────────────────────────
SESSION_SECRET=change_me_in_production
HMAC_CONVERSATION_SECRET=change_me_in_production
VOICE_URL_SIGNING_SECRET=change_me_in_production

# ── Redis (BullMQ) ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── GMI Cloud — LLM (api.gmi-serving.com) ────────────────────────────────────
GMI_API_KEY=your_gmi_api_key_here
GMI_API_BASE_URL=https://api.gmi-serving.com/v1
GMI_TEXT_MODEL=deepseek-ai/DeepSeek-V3.2

# ── GMI Cloud — TTS async queue (console.gmicloud.ai — DISTINCT from LLM host) ─
# Confirmed in 03-01-GMI-TTS-CONTRACT.md (2026-05-30).
GMI_TTS_BASE_URL=https://console.gmicloud.ai
GMI_TTS_MODEL_ID=minimax-tts-speech-2.6-hd
# Preset voice_id used when twins.voice_id is null (before clone Step A runs).
GMI_TTS_FALLBACK_VOICE_ID=English_expressive_narrator
# Optional — poll interval (ms). Default: 1500.
GMI_TTS_POLL_INTERVAL_MS=1500
# Optional — overall submit+poll+fetch timeout (ms). Default: 30000.
GMI_TTS_TIMEOUT_MS=30000

# ── OpenAI (moderation only — NOT for text generation) ───────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Helicone observability (optional) ────────────────────────────────────────
HELICONE_API_KEY=

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN_LALA=
TELEGRAM_BOT_TOKEN_FAN_TWIN=
WEBHOOK_URL=
WEBHOOK_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Object Storage ────────────────────────────────────────────────────────────
REPLIT_OBJECT_STORAGE_BUCKET=your_bucket_name_here

# ── Founder Telegram ─────────────────────────────────────────────────────────
FOUNDER_TELEGRAM_USER_ID=
TELEGRAM_BOT_TOKEN_DONNA=

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=
