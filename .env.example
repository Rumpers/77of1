# 7of1 — environment variables
# Copy this file to .env.local for local development (never commit real values).
# In Replit, set these as Secrets (the Replit Secrets panel maps them to env vars at runtime).
# In production (GCP Cloud Run), set these as Cloud Run environment variables / Secret Manager refs.
#
# Required vars are marked [REQUIRED] — the API server will crash on startup if these are missing.
# Optional vars are marked [OPTIONAL] — features degrade gracefully without them.

# ──────────────────────────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────────────────────────

# TCP port the API server listens on. Replit sets this automatically.
# [REQUIRED]
PORT=8080

NODE_ENV=development

# ──────────────────────────────────────────────────────────────────────────────
# Database (Replit PostgreSQL)
# ──────────────────────────────────────────────────────────────────────────────

# Replit PostgreSQL connection string — auto-injected by Replit in hosted envs.
# For local dev: set to your dev Postgres URL.
# [REQUIRED]
DATABASE_URL=

# Optional: direct (non-pooled) connection URL for drizzle-kit push DDL.
# Use this if DATABASE_URL points to a PgBouncer pooled URL (port 6543).
# [OPTIONAL]
DATABASE_URL_DIRECT=

# ──────────────────────────────────────────────────────────────────────────────
# Redis / BullMQ job queue
# ──────────────────────────────────────────────────────────────────────────────

# Redis connection URL. Queue features are disabled if not set.
# Format: redis://:<password>@<host>:<port>
# [OPTIONAL]
REDIS_URL=

# ──────────────────────────────────────────────────────────────────────────────
# AI provider (GMI)
# ──────────────────────────────────────────────────────────────────────────────

# GMI API key for text/voice/video generation
# [OPTIONAL — AI generation features are disabled without this]
GMI_API_KEY=

# GMI API base URL (e.g. https://api.gmi.ai/v1)
# [OPTIONAL]
GMI_API_BASE_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Application URL
# ──────────────────────────────────────────────────────────────────────────────

# Canonical public URL of this deployment — used in magic link redirects.
# Must be the Replit deployment URL in Replit, or the Cloud Run service URL in GCP.
# No trailing slash.
# [OPTIONAL — magic links will fail if not set]
NEXT_PUBLIC_APP_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────────────────────────────────────

# Sentry DSN for error reporting
# [OPTIONAL]
SENTRY_DSN=

# Helicone API key for LLM observability
# [OPTIONAL]
HELICONE_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Health check auth
# ──────────────────────────────────────────────────────────────────────────────

# Shared secret for protected health endpoints (/api/health/db, /api/health/queue, /api/health/providers).
# Set X-Health-Secret: <value> on requests to those endpoints.
# If not set, the endpoints are open (acceptable for dev; set this in production).
# Generate with: openssl rand -hex 32
# [OPTIONAL — recommended in production]
HEALTH_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Session & conversation security
# ──────────────────────────────────────────────────────────────────────────────

# Secret for signing session cookies. Generate with: openssl rand -hex 32
# [REQUIRED]
SESSION_SECRET=

# HMAC secret for signing conversation_id tokens (prevents session theft).
# Generate with: openssl rand -hex 32
# [REQUIRED]
HMAC_CONVERSATION_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Telegram bots
# ──────────────────────────────────────────────────────────────────────────────

# Hermes creator-onboarding bot token (from @BotFather)
# [REQUIRED for Hermes]
TELEGRAM_BOT_TOKEN_LALA=

# Fan-twin bot token (from @BotFather)
# [REQUIRED for fan-twin bot]
TELEGRAM_BOT_TOKEN_FAN_TWIN=

# Founder Telegram chat ID for L5 safety alerts (DM @userinfobot to get yours).
# Numeric value (e.g. 123456789). Without this, L5 falls back to Sentry-only.
# [OPTIONAL — strongly recommended]
FOUNDER_TELEGRAM_CHAT_ID=

# Comma-separated Telegram user_ids allowed to run founder-only Hermes commands
# (e.g. /review_masks mask review queue — ONBOARD-04). If unset, NO ONE is a
# founder and /review_masks is inaccessible (Hermes warns at boot).
# [OPTIONAL — required only to use /review_masks]
FOUNDER_TELEGRAM_USER_ID=

# ──────────────────────────────────────────────────────────────────────────────
# OpenAI (moderation only — NOT for LLM text generation)
# ──────────────────────────────────────────────────────────────────────────────

# OpenAI API key — used ONLY for omni-moderation-latest; GMI Cloud handles all LLM generation.
# [REQUIRED for moderation pipeline]
OPENAI_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# SignWell (KYC e-signature)
# ──────────────────────────────────────────────────────────────────────────────

# SignWell API key for sending/tracking personality-rights agreements
# [REQUIRED for KYC onboarding]
SIGNWELL_API_KEY=

# SignWell document template ID for the personality-rights agreement
# [REQUIRED for KYC onboarding]
SIGNWELL_TEMPLATE_ID=
