# Copy to .env and fill in. .env is gitignored.

# Required — your Replicate API token (https://replicate.com/account/api-tokens)
REPLICATE_API_TOKEN=

# Required — your Replicate username/org (the OWNER the trained model is pushed to).
# The destination model will be created as: <REPLICATE_OWNER>/<DEST_MODEL_NAME from config.ts>
REPLICATE_OWNER=

# Optional — see results pushed to YOUR OWN Telegram (founder-internal only).
# Leave blank to skip. Do NOT point this at the fan-twin bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
