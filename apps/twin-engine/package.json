{
  "name": "@7of1/twin-engine",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark": "tsx src/benchmark/run-benchmark.ts",
    "benchmark:moderation": "tsx src/benchmark/run-moderation-benchmark.ts"
  },
  "dependencies": {
    "@7of1/ai-providers": "workspace:*",
    "@7of1/db": "workspace:*",
    "@7of1/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
